#!/bin/bash
#
# runs dh_virtualenv to build the virtualenv in the build directory,
# and then runs the trial tests against the installed synapse.

set -e

export DEB_BUILD_OPTIONS="nocheck ${DEB_BUILD_OPTIONS}"
export HOME=/tmp
export DH_VIRTUALENV_INSTALL_ROOT=/opt/venvs
export PIP_NO_INDEX=1
export PIP_FIND_LINKS="$(pwd)/vendor/wheels"

# maturin drops $CARGO and then resolves "cargo" from PATH inside build
# isolation, so provide an explicit shim directory with the desired toolchain.
RUST_SHIM_DIR="$(mktemp -d)"
ln -sf /usr/lib/rust-1.96/bin/cargo "${RUST_SHIM_DIR}/cargo"
ln -sf /usr/lib/rust-1.96/bin/rustc "${RUST_SHIM_DIR}/rustc"
export PATH="${RUST_SHIM_DIR}:${PATH}"
export CARGO="${RUST_SHIM_DIR}/cargo"
export RUSTC="${RUST_SHIM_DIR}/rustc"
export MATURIN_NO_INSTALL_RUST=1
CARGO_HOME_DIR="$(mktemp -d)"
cat > "${CARGO_HOME_DIR}/config.toml" <<EOF
[source.crates-io]
replace-with = "vendored-sources"

[source.vendored-sources]
directory = "$(pwd)/vendor/cargo"
EOF
export CARGO_HOME="${CARGO_HOME_DIR}"
export CARGO_NET_OFFLINE=true
trap 'rm -rf "$RUST_SHIM_DIR" "$CARGO_HOME_DIR"' EXIT
echo "Using cargo from: $(command -v cargo)"
cargo --version
echo "Using rustc from: $(command -v rustc)"
rustc --version
POETRY_VERSION="$(cat vendor/poetry-version.txt 2>/dev/null || echo 2.1.1)"
POETRY_EXPORT_EXTRAS="$(cat vendor/export-extras.json 2>/dev/null || echo '[\"all\",\"test\",\"systemd\"]')"

# make sure that the virtualenv links to the specific version of python, by
# dereferencing the python3 symlink.
#
# Otherwise, if somebody tries to install (say) the stretch package on buster,
# they will get a confusing error about "No module named 'synapse'", because
# python won't look in the right directory. At least this way, the error will
# be a *bit* more obvious.
#
SNAKE=$(readlink -e /usr/bin/python3)

# try to set the CFLAGS so any compiled C extensions are compiled with the most
# generic as possible x64 instructions, so that compiling it on a new Intel chip
# doesn't enable features not available on older ones or AMD.
#
# TODO: add similar things for non-amd64, or figure out a more generic way to
# do this.

case "$(dpkg-architecture -qDEB_HOST_ARCH)" in
    amd64)
        export CFLAGS="-march=x86-64"
        ;;
    arm64)
        export CFLAGS="-march=armv8-a"
        ;;
    armhf)
        export CFLAGS="-march=armv7-a+fp -mfpu=vfpv3-d16"
        ;;
    i386)
        export CFLAGS="-march=i686"
        ;;
    ppc64el)
        export CFLAGS="-mcpu=power8"
        ;;
    riscv64)
        export CFLAGS="-march=rv64gc -mabi=lp64d"
        ;;
    s390x)
        export CFLAGS="-march=zEC12"
        ;;
    *)
        echo "Unknown architecture: $(dpkg-architecture -qDEB_HOST_ARCH), leaving CFLAGS unset" >&2
        ;;
esac

if [ ! -f vendor/exported_requirements.txt ]; then
    # Fallback path if vendored requirements were not prepared ahead of time.
    TEMP_VENV="$(mktemp -d)"
    python3 -m venv "$TEMP_VENV"
    source "$TEMP_VENV/bin/activate"
    pip install \
        --no-index \
        --find-links "$PIP_FIND_LINKS" \
        -U pip setuptools wheel
    pip install \
        --no-index \
        --find-links "$PIP_FIND_LINKS" \
        "poetry==${POETRY_VERSION}" poetry-plugin-export==1.9.0
    POETRY_EXPORT_ARGS="$(
    python3 - <<'PY'
import json
from pathlib import Path
extras = json.loads(Path("vendor/export-extras.json").read_text(encoding="utf-8"))
for extra in extras:
    print(f"--extras {extra}")
PY
    )"
    # shellcheck disable=SC2086
    poetry export $POETRY_EXPORT_ARGS -o vendor/exported_requirements.txt
    deactivate
    rm -rf "$TEMP_VENV"
fi

DH_VIRTUALENV_PREINSTALL_ARGS=(
    --preinstall="mock"
    --preinstall="wheel"
)

if [ -f vendor/build-requirements.txt ] && [ -s vendor/build-requirements.txt ]; then
    echo "Skipping global preinstall of vendor/build-requirements.txt; package-specific build isolation will install these from the vendored wheel directory."
fi

# Keep installs fully offline from the vendored wheel directory. We intentionally
# do not pass --no-deps here: pip needs dependency resolution inside build
# isolation for vendored sdists such as maturin and pydantic-core.
dh_virtualenv \
    --install-suffix "matrix-synapse" \
    --builtin-venv \
    --python "$SNAKE" \
    --upgrade-pip \
    "${DH_VIRTUALENV_PREINSTALL_ARGS[@]}" \
    --extra-pip-arg="--no-index" \
    --extra-pip-arg="--find-links=$(pwd)/vendor/wheels" \
    --extra-pip-arg="--no-cache-dir" \
    --extra-pip-arg="--compile" \
    --extra-pip-arg="--verbose" \
    --requirements="vendor/exported_requirements.txt"

PACKAGE_BUILD_DIR="$(pwd)/debian/matrix-synapse-py3"
VIRTUALENV_DIR="${PACKAGE_BUILD_DIR}${DH_VIRTUALENV_INSTALL_ROOT}/matrix-synapse"
TARGET_PYTHON="${VIRTUALENV_DIR}/bin/python"

case "$DEB_BUILD_OPTIONS" in
    *nocheck*)
        # Skip running tests if "nocheck" present in $DEB_BUILD_OPTIONS
        ;;

    *)
        # Copy tests to a temporary directory so that we can put them on the
        # PYTHONPATH without putting the uninstalled synapse on the pythonpath.
        tmpdir=$(mktemp -d)
        trap 'rm -r $tmpdir' EXIT

        cp -r tests "$tmpdir"

        # To avoid pulling in the unbuilt Synapse in the local directory
        pushd /

        PYTHONPATH="$tmpdir" \
            "${TARGET_PYTHON}" -m twisted.trial --reporter=text -j2 tests

        popd

        ;;
esac

# build the config file
"${TARGET_PYTHON}" "${VIRTUALENV_DIR}/bin/generate_config" \
        --config-dir="/etc/matrix-synapse" \
        --data-dir="/var/lib/matrix-synapse" |
    perl -pe '
# tweak the paths to the tls certs and signing keys
/^tls_.*_path:/ and s/SERVERNAME/homeserver/;
/^signing_key_path:/ and s/SERVERNAME/homeserver/;

# tweak the pid file location
/^pid_file:/ and s#:.*#: "/var/run/matrix-synapse.pid"#;

# tweak the path to the log config
/^log_config:/ and s/SERVERNAME\.log\.config/log.yaml/;

# tweak the path to the media store
/^media_store_path:/ and s#/media_store#/media#;

# remove the server_name setting, which is set in a separate file
/^server_name:/ and $_ = "#\n# This is set in /etc/matrix-synapse/conf.d/server_name.yaml for Debian installations.\n# $_";

# remove the report_stats setting, which is set in a separate file
/^# report_stats:/ and $_ = "";

' > "${PACKAGE_BUILD_DIR}/etc/matrix-synapse/homeserver.yaml"

# build the log config file
"${TARGET_PYTHON}" "${VIRTUALENV_DIR}/bin/generate_log_config" \
        --output-file="${PACKAGE_BUILD_DIR}/etc/matrix-synapse/log.yaml"

# add a dependency on the right version of python to substvars.
PYPKG=$(basename "$SNAKE")
echo "synapse:pydepends=$PYPKG" >> debian/matrix-synapse-py3.substvars


# add a couple of triggers.  This is needed so that dh-virtualenv can rebuild
# the venv when the system python changes (see
# https://dh-virtualenv.readthedocs.io/en/latest/tutorial.html#step-2-set-up-packaging-for-your-project)
#
# we do it here rather than the more conventional way of just adding it to
# debian/matrix-synapse-py3.triggers, because we need to add a trigger on the
# right version of python.
cat >>"debian/.debhelper/generated/matrix-synapse-py3/triggers" <<EOF
# triggers for dh-virtualenv
interest-noawait $SNAKE
interest dh-virtualenv-interpreter-update

EOF
